<!-- Playlist Item Modal -->
<dialog class="modal modal-lg" data-modal-target="dialog" data-action="click->modal#backdropClose">
  <div class="modal-card">
    <button type="button" data-action="modal#close:prevent" class="absolute top-4 right-4 text-gray-400 hover:text-gray-600">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
        <line x1="18" x2="6" y1="6" y2="18"></line>
        <line x1="6" x2="18" y1="6" y2="18"></line>
      </svg>
      <span class="sr-only">Close</span>
    </button>

    <div class="p-6">
      <%= form_with model: [@qr_code, :playlist, PlaylistItem.new], local: true do |form| %>
        
        <h3 class="text-lg font-semibold mb-6">Add Playlist Item</h3>
        
        <div class="space-y-6">
          <!-- Item Name -->
          <div class="form-group">
            <%= form.label :title, "Item Name" %>
            <%= form.text_field :title, class: "form-control", placeholder: "Enter item name...", required: true, autofocus: true %>
            <p class="form-hint">Give this playlist item a descriptive name</p>
          </div>

          <!-- Content Type -->
          <div class="form-group">
            <%= form.label :schema_type, "Content Type" %>
            <div class="flex flex-wrap gap-2 mt-2" role="group">
              <button type="button" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" data-schema-type="url" id="btn-url">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9v-9m0-9v9" />
                </svg>
                Website
              </button>
              <button type="button" class="inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" data-schema-type="phone" id="btn-phone">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
                Phone
              </button>
              <button type="button" class="inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" data-schema-type="sms" id="btn-sms">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                </svg>
                SMS
              </button>
              <button type="button" class="inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" data-schema-type="email" id="btn-email">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                Email
              </button>
              <button type="button" class="inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" data-schema-type="whatsapp" id="btn-whatsapp">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                </svg>
                WhatsApp
              </button>
            </div>
            <%= form.hidden_field :schema_type, value: "url" %>
          </div>

          <!-- Dynamic Fields Container -->
          <div id="dynamic-fields">
            <!-- URL Fields (default) -->
            <div id="url-fields" class="space-y-3">
              <div class="form-group">
                <%= form.label :target_value, "Website URL" %>
                <%= form.url_field :target_value, class: "form-control", placeholder: "https://example.com", required: true %>
              </div>
            </div>

            <!-- Phone Fields -->
            <div id="phone-fields" class="space-y-3" style="display: none;">
              <div class="form-group">
                <%= form.label :target_value, "Phone Number" %>
                <%= form.telephone_field :target_value, class: "form-control", placeholder: "+1234567890" %>
                <p class="form-hint">Include country code (e.g., +1)</p>
              </div>
            </div>

            <!-- SMS Fields -->
            <div id="sms-fields" class="space-y-3" style="display: none;">
              <div class="form-group">
                <%= form.label :target_value, "Phone Number" %>
                <%= form.telephone_field :target_value, class: "form-control", placeholder: "+1234567890" %>
                <p class="form-hint">Include country code (e.g., +1)</p>
              </div>
              <div class="form-group">
                <%= form.label :message, "SMS Message" %>
                <%= form.text_area :message, class: "form-control", rows: 3, placeholder: "Enter the message to send..." %>
              </div>
            </div>

            <!-- Email Fields -->
            <div id="email-fields" class="space-y-3" style="display: none;">
              <div class="form-group">
                <%= form.label :target_value, "Email Address" %>
                <%= form.email_field :target_value, class: "form-control", placeholder: "example@email.com" %>
              </div>
              <div class="form-group">
                <%= form.label :subject, "Email Subject" %>
                <%= form.text_field :subject, class: "form-control", placeholder: "Enter email subject..." %>
              </div>
              <div class="form-group">
                <%= form.label :message, "Email Message" %>
                <%= form.text_area :message, class: "form-control", rows: 4, placeholder: "Enter your message..." %>
              </div>
            </div>

            <!-- WhatsApp Fields -->
            <div id="whatsapp-fields" class="space-y-3" style="display: none;">
              <div class="form-group">
                <%= form.label :target_value, "WhatsApp Number" %>
                <%= form.telephone_field :target_value, class: "form-control", placeholder: "+1234567890" %>
                <p class="form-hint">Include country code (e.g., +1)</p>
              </div>
              <div class="form-group">
                <%= form.label :message, "WhatsApp Message" %>
                <%= form.text_area :message, class: "form-control", rows: 3, placeholder: "Enter your WhatsApp message..." %>
              </div>
            </div>
          </div>
        </div>

        <!-- Actions -->
        <div class="flex justify-end space-x-4 pt-6 mt-6 border-t">
          <%= form.submit "Add Item", class: "btn btn-primary", data: { disable_with: "Adding..." } %>
        </div>
      <% end %>
    </div>
  </div>
</dialog>

<script>
  // Simple vanilla JavaScript for schema switching
  document.addEventListener('DOMContentLoaded', function() {
    const modal = document.querySelector('[data-modal-target="dialog"]');
    if (!modal) return;
    
    const buttons = modal.querySelectorAll('button[data-schema-type]');
    const hiddenField = modal.querySelector('input[name="playlist_item[schema_type]"]');
    
    buttons.forEach(button => {
      button.addEventListener('click', function(e) {
        e.preventDefault();
        const schemaType = this.dataset.schemaType;
        
        // Update button states
        buttons.forEach(btn => {
          // Reset to secondary state
          btn.classList.remove('bg-blue-600', 'text-white', 'border-transparent');
          btn.classList.add('bg-white', 'text-gray-700', 'border-gray-300');
        });
        // Set this button to primary state
        this.classList.remove('bg-white', 'text-gray-700', 'border-gray-300');
        this.classList.add('bg-blue-600', 'text-white', 'border-transparent');
        
        // Update hidden field
        if (hiddenField) {
          hiddenField.value = schemaType;
        }
        
        // Show/hide fields
        const allFields = modal.querySelectorAll('#dynamic-fields > div');
        allFields.forEach(field => field.style.display = 'none');
        
        const targetField = modal.querySelector(`#${schemaType}-fields`);
        if (targetField) {
          targetField.style.display = 'block';
        }
      });
    });
  });
</script>