<% content_for :title, t("qr_codes.edit.title") %>

<div class="container mx-auto p-4">
  <div class="mb-6">
    <%= link_to t("common.back"), qr_code_path(@qr_code), 
        class: "btn btn-secondary btn-sm mb-4" %>
    <h1><%= t("qr_codes.edit.title") %></h1>
    <p class="text-gray-600">
      <%= t("qr_codes.edit.description", name: @qr_code.name) %>
    </p>
  </div>

  <%= render 'form', qr_code: @qr_code %>
</div>