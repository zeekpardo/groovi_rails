<% content_for :title, @shortened_link.title %>

<div class="container mx-auto p-4">
  <!-- Header -->
  <div class="card card-cta-basic mb-6">
    <div class="lg:flex-1">
      <h1><%= @shortened_link.title %></h1>
      <% if @shortened_link.description.present? %>
        <p class="text-gray-600"><%= @shortened_link.description %></p>
      <% end %>
      <div class="mt-2">
        <span class="pill pill-sm <%= schema_color(@shortened_link.schema_type) %>">
          <%= @shortened_link.schema_display_name %>
        </span>
        <% if @shortened_link.expired? %>
          <span class="pill pill-sm pill-danger ml-2">Expired</span>
        <% elsif @shortened_link.active? %>
          <span class="pill pill-sm pill-success ml-2">Active</span>
        <% else %>
          <span class="pill pill-sm pill-secondary ml-2">Inactive</span>
        <% end %>
      </div>
    </div>
    <div class="lg:p-0 pt-4 space-x-2">
      <%= button_tag "Copy Link", 
          class: "btn btn-primary", 
          data: { 
            controller: "clipboard", 
            clipboard_text_value: @shortened_link.full_url 
          } %>
      <%= link_to t(".edit"), edit_account_shortened_link_path(current_account, @shortened_link), 
          class: "btn btn-secondary" %>
    </div>
  </div>

  <div class="grid lg:grid-cols-3 gap-6">
    <!-- Link Details -->
    <div class="lg:col-span-2">
      <div class="card">
        <h3>Link Details</h3>
        
        <dl class="space-y-4">
          <div>
            <dt class="font-medium text-gray-600">Short URL</dt>
            <dd class="mt-1">
              <code class="text-sm bg-gray-100 px-2 py-1 rounded"><%= @shortened_link.full_url %></code>
            </dd>
          </div>
          
          <div>
            <dt class="font-medium text-gray-600">Target</dt>
            <dd class="mt-1 break-all"><%= @shortened_link.target_value %></dd>
          </div>
          
          <% if @shortened_link.custom_slug? %>
            <div>
              <dt class="font-medium text-gray-600">Custom Slug</dt>
              <dd class="mt-1"><code><%= @shortened_link.custom_slug %></code></dd>
            </div>
          <% end %>
          
          <% if @shortened_link.expires_at.present? %>
            <div>
              <dt class="font-medium text-gray-600">Expires</dt>
              <dd class="mt-1">
                <%= time_tag @shortened_link.expires_at, @shortened_link.expires_at.strftime("%B %d, %Y at %I:%M %p") %>
              </dd>
            </div>
          <% end %>
          
          <% if @shortened_link.requires_metadata? %>
            <% if @shortened_link.subject.present? %>
              <div>
                <dt class="font-medium text-gray-600">Subject</dt>
                <dd class="mt-1"><%= @shortened_link.subject %></dd>
              </div>
            <% end %>
            
            <% if @shortened_link.message.present? %>
              <div>
                <dt class="font-medium text-gray-600">Message</dt>
                <dd class="mt-1"><%= simple_format(@shortened_link.message) %></dd>
              </div>
            <% end %>
          <% end %>
          
          <div>
            <dt class="font-medium text-gray-600">Created</dt>
            <dd class="mt-1">
              <%= time_tag @shortened_link.created_at, 
                  @shortened_link.created_at.strftime("%B %d, %Y at %I:%M %p") %>
              <% if @shortened_link.created_by.present? %>
                by <%= @shortened_link.created_by.name %>
              <% end %>
            </dd>
          </div>
        </dl>
      </div>
    </div>

    <!-- Analytics Sidebar -->
    <div>
      <!-- Click Stats -->
      <div class="card mb-4">
        <h4>Click Statistics</h4>
        
        <div class="space-y-3">
          <div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600">Total Clicks</span>
              <span class="font-bold text-lg"><%= number_with_delimiter(@click_stats[:total_clicks]) %></span>
            </div>
          </div>
          
          <div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600">Last 7 Days</span>
              <span class="font-bold"><%= number_with_delimiter(@click_stats[:recent_clicks]) %></span>
            </div>
          </div>
          
          <div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600">Unique Visitors</span>
              <span class="font-bold"><%= number_with_delimiter(@click_stats[:unique_ips]) %></span>
            </div>
          </div>
        </div>
      </div>

      <!-- Top Countries -->
      <% if @click_stats[:top_countries].any? %>
        <div class="card mb-4">
          <h4>Top Countries</h4>
          <div class="space-y-2">
            <% @click_stats[:top_countries].each do |country, count| %>
              <div class="flex justify-between">
                <span><%= country || "Unknown" %></span>
                <span><%= count %></span>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <!-- Top Devices -->
      <% if @click_stats[:top_devices].any? %>
        <div class="card">
          <h4>Top Devices</h4>
          <div class="space-y-2">
            <% @click_stats[:top_devices].each do |device, count| %>
              <div class="flex justify-between">
                <span><%= device&.humanize || "Unknown" %></span>
                <span><%= count %></span>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Recent Clicks -->
  <% if @recent_clicks.any? %>
    <div class="card mt-6">
      <h3><%= t(".recent_clicks") %></h3>
      <div class="overflow-x-auto">
        <table class="table">
          <thead>
            <tr>
              <th>Time</th>
              <th>Country</th>
              <th>Device</th>
              <th>Browser</th>
            </tr>
          </thead>
          <tbody>
            <% @recent_clicks.each do |click| %>
              <tr>
                <td>
                  <%= time_tag click.clicked_at, 
                      distance_of_time_in_words_to_now(click.clicked_at) + " ago" %>
                </td>
                <td><%= click.country || "Unknown" %></td>
                <td><%= click.device_type&.humanize || "Unknown" %></td>
                <td><%= click.browser || "Unknown" %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>
</div>