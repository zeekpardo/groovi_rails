<% content_for :title, t(".title") %>

<div class="container mx-auto p-4">
  <div class="mb-6">
    <h1><%= t(".title") %>: <%= @shortened_link.title %></h1>
    <div class="space-x-2">
      <%= link_to "← Back to Links", account_shortened_links_path(current_account), 
          class: "btn btn-link" %>
      <%= link_to "View Details", account_shortened_link_path(current_account, @shortened_link), 
          class: "btn btn-secondary btn-sm" %>
    </div>
  </div>

  <%= render 'form', account: current_account, shortened_link: @shortened_link %>
</div>