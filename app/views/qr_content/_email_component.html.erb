<%
  field_name_prefix = local_assigns.fetch(:field_name_prefix, "shortened_link")
  email_value = local_assigns.fetch(:email_value, "")
  subject_value = local_assigns.fetch(:subject_value, "")
  body_value = local_assigns.fetch(:body_value, "")
  required = local_assigns.fetch(:required, false)
%>

<div class="space-y-3">
  <div class="form-group">
    <%= label_tag "#{field_name_prefix}_target_value", t("qr_codes.form.email_address") %>
    <%= email_field_tag "#{field_name_prefix}[target_value]", 
        email_value,
        class: "form-control",
        placeholder: "contact@example.com",
        required: required,
        data: { 
          action: "input->schema-switcher#updatePreview"
        } %>
  </div>
  
  <div class="form-group">
    <%= label_tag "#{field_name_prefix}_metadata_subject", t("qr_codes.form.email_subject") %>
    <%= text_field_tag "#{field_name_prefix}[metadata][subject]", 
        subject_value,
        class: "form-control",
        placeholder: t("qr_codes.form.email_subject_placeholder"),
        data: { 
          action: "input->schema-switcher#updatePreview"
        } %>
  </div>
  
  <div class="form-group">
    <%= label_tag "#{field_name_prefix}_metadata_message", t("qr_codes.form.email_body") %>
    <%= text_area_tag "#{field_name_prefix}[metadata][message]", 
        body_value,
        class: "form-control",
        rows: 3,
        placeholder: t("qr_codes.form.email_body_placeholder"),
        data: { 
          action: "input->schema-switcher#updatePreview"
        } %>
  </div>
</div>